# aksrtblog-api environment variables

# PostgreSQL
DB_HOST=localhost
# Host-published PostgreSQL port. The API container still connects to db:5432
# inside the Docker network unless EXTERNAL_DB_URL is set.
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_NAME=aksrtblog

# Optional: set only when using an external PostgreSQL service.
# EXTERNAL_DB_URL=postgres://postgres:your_secure_password_here@your-db-host:5432/aksrtblog

# CORS
CORS_ORIGIN=*

# Public site URL
SITE_URL=http://localhost:3000

# Upload persistence directory
UPLOADS_DIR=./data/uploads

# Comment unlock JWT secret
COMMENT_UNLOCK_JWT_SECRET=change-me-comment-unlock-secret
