# ============================================
# aksrtblog-api 环境变量配置
# ============================================

# PostgreSQL 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_NAME=aksrtblog

# CORS 配置（生产环境建议设置具体域名）
CORS_ORIGIN=*

# 公开访问 URL（前端地址）
SITE_URL=http://localhost:3000

# 数据持久化目录（相对于 docker-compose.yml 所在目录）
UPLOADS_DIR=./data/uploads
