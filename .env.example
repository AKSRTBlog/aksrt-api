# aksrtblog-api environment variables

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_NAME=aksrtblog

# CORS
CORS_ORIGIN=*

# Public site URL
SITE_URL=http://localhost:3000

# Upload persistence directory
UPLOADS_DIR=./data/uploads

# Comment unlock JWT secret
COMMENT_UNLOCK_JWT_SECRET=change-me-comment-unlock-secret
